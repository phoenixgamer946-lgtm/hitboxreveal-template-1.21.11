{
	"schemaVersion": 1,
	"id": "hitboxreveal",
	"version": "${version}",
	"name": "Hitbox Reveal",
	"description": "Reveals a player's hitbox when you land a hit on them. Supports color states, gradients, pulse, fade, and more.",
	"authors": [
		"lwkSlick"
	],
	"license": "MIT",
	"contact": {
		"homepage": "https://modrinth.com/user/6fLXr7R5",
		"issues": "https://discord.gg/Kk4gBYNMJ9"
	},

	"icon": "assets/hitboxreveal/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.lwkslick.hitboxreveal.HitboxReveal"
		],
		"client": [
			"com.lwkslick.hitboxreveal.client.HitboxRevealClient"
		],
		"modmenu": [
			"com.lwkslick.hitboxreveal.client.ModMenuIntegration"
		]
	},
	"mixins": [
		"hitboxreveal.mixins.json",
		{
			"config": "hitboxreveal.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"modmenu": "*",
		"yet_another_config_lib_v3": "*"
	}
}